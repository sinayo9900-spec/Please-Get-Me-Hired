# LLM: CLI 구독 재활용 (API 키 불필요). 각 CLI는 머신에 사전 로그인되어 있어야 함.
LLM_PROVIDER=claude        # claude | gemini | codex
LLM_CONCURRENCY=2          # 동시 실행 프로세스 수
LLM_TIMEOUT_MS=60000       # CLI 호출 타임아웃(ms)

# 메일 (SMTP) — Gmail은 앱 비밀번호 사용
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=                 # Gmail 앱 비밀번호
MAIL_FROM="Please-Get-Me-Hired <you@example.com>"

# 저장소 / 서버
DATABASE_URL=file:./data/app.db
DASHBOARD_PORT=3000
